# top-most EditorConfig file
root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
indent_style = space
indent_size = 4
trim_trailing_whitespace = true

[*.py]
max_line_length = 120

[*.{ts,js,mjs,json}]
indent_size = 2

[*.rs]
indent_size = 4

[*.{yml,yaml}]
indent_size = 2

[*.md]
max_line_length = off
trim_trailing_whitespace = false

[*.toml]
indent_size = 4
